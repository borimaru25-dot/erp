{
  "version": 2,
  "builds": [
    {
      "src": "api/files/*.py",
      "use": "@vercel/python",
      "config": {
        "runtime": "python3.11",
        "includeFiles": ["api/_lib/**", "api/__init__.py"]
      }
    },
    {
      "src": "api/ai/*.py",
      "use": "@vercel/python",
      "config": {
        "runtime": "python3.11",
        "includeFiles": ["api/_lib/**", "api/__init__.py"]
      }
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    },
    {
      "src": "pages/**",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    { "source": "/api/files/temp-upload",     "destination": "/api/files/temp_upload.py" },
    { "source": "/api/files/temp-list",       "destination": "/api/files/temp_list.py" },
    { "source": "/api/files/temp/:id",        "destination": "/api/files/temp_detail.py" },

    { "source": "/api/files/save-final",      "destination": "/api/files/save_final.py" },
    { "source": "/api/files/final-list",      "destination": "/api/files/final_list.py" },
    { "source": "/api/files/final/:id",       "destination": "/api/files/final_detail.py" },

    { "source": "/api/files/save-excel",      "destination": "/api/files/save_excel.py" },
    { "source": "/api/files/save-excel-data", "destination": "/api/files/save_excel_data.py" },

    { "source": "/api/ai/chat",               "destination": "/api/ai/chat.py" },
    { "source": "/api/ai/generate-slides",    "destination": "/api/ai/generate_slides.py" },
    { "source": "/api/ai/generate-approval",  "destination": "/api/ai/generate_approval.py" },

    { "source": "/public/:path*",             "destination": "/public/:path*" },
    { "source": "/pages/:path*",              "destination": "/pages/:path*" },
    { "source": "/",                          "destination": "/pages/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods",
          "value": "GET, POST, PUT, DELETE, OPTIONS" },
        { "key": "Access-Control-Allow-Headers",
          "value": "Content-Type, Authorization" }
      ]
    }
  ]
}
